# General
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
DEBUG=true
FRONTEND_URL=http://localhost:3020

# Database
DATABASE_URL=postgresql+asyncpg://cvreview:cvreview_pass@db:5432/cvreview

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# AI Provider
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Gemini AI (legacy fallback)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_GEN_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# File Uploads
UPLOAD_DIR=uploads

# SMTP
# Default docker-compose setup uses the local Mailpit container.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@cvreview.local
SMTP_FROM_NAME=CV Review
SMTP_USE_TLS=false

# MinIO Object Storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=cv-files
MINIO_USE_SSL=false

# CORS
CORS_ORIGINS=["http://localhost:3020","http://localhost:5120"]
